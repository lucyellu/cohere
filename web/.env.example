# Cohere web env (committed template — copy to web/.env and fill in).
# Vite only exposes VITE_-prefixed vars to the browser.

# Google Maps JS API key (satellite venue view + Street View).
# Restrict by HTTP referrer in production. Also set in Netlify env vars.
VITE_GOOGLE_MAPS_KEY=

# Supabase Realtime presence (optional — blank = gateway-polling fallback).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
