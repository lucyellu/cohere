# Copy to .env and fill in. .env is gitignored.
MUSIXMATCH_API_KEY=
JAMBASE_API_KEY=
YOUTUBE_API_KEY=
SONGSTATS_API_KEY=
SETLISTFM_API_KEY=
LALALAI_API_KEY=
ELEVENLABS_API_KEY=

# Free-tier text generation (OpenAI-compatible). From the ai-free workbench.
# Text only — these do not generate images. Optional model overrides below.
CEREBRAS_API_KEY=
GROQ_API_KEY=
CEREBRAS_TEXT_MODEL=gpt-oss-120b
GROQ_TEXT_MODEL=llama-3.3-70b-versatile

# Image generation. Pollinations (FLUX) is free + KEYLESS — nothing to set; it's
# the live fallback for "✨ AI scene" when Gemini is off. HuggingFace FLUX.1-schnell
# is optional (stays "no key" until set): https://huggingface.co/settings/tokens
HF_TOKEN=

USE_MOCK_DATA=true
PORT=5001
